---
const { title = "Dashboard" } = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
    </head>

    <body class="flex min-h-screen bg-gray-50">
        <!-- Mobile overlay -->
        <div
            id="sidebarOverlay"
            class="fixed inset-0 bg-black/40 hidden md:hidden z-40"
        >
            <!-- Sidebar -->
            <aside
                id="sidebar"
                class="fixed
            top-0 left-0
            h-full w-64
            bg-white border-r
            transform -translate-x-full
            transition-transform duration-300 ease-in-out
            z-50"
            >
                <div class="p-4 font-bold text-lg">My App</div>

                <nav class="p-4 space-y-2">
                    <a class="block hover:bg-gray-100 p-2 rounded" href="/"
                        >Home</a
                    >
                    <a
                        class="block hover:bg-gray-100 p-2 rounded"
                        href="/dashboard">Dashboard</a
                    >
                    <a
                        class="block hover:bg-gray-100 p-2 rounded"
                        href="/settings">Settings</a
                    >
                </nav>
            </aside>
        </div>
        <!-- Main -->
        <div class="flex-1 flex flex-col">
            <!-- Top bar -->
            <header class="h-14 bg-white border-b flex items-center px-4">
                <button
                    id="menuBtn"
                    class="md:hidden p-2 rounded hover:bg-gray-100"
                >
                    ☰
                </button>

                <h1 class="ml-3 font-semibold">{title}</h1>
            </header>

            <!-- Content -->
            <main class="p-4">
                <slot />
            </main>
        </div>

        <!-- JS (works with Astro SPA navigation) -->
        <script is:inline>
            console.log("inline");
            const sidebar = document.getElementById("sidebar");
            const overlay = document.getElementById("sidebarOverlay");
            const btn = document.getElementById("menuBtn");

            function openMenu() {
                sidebar?.classList.remove("-translate-x-full");
                overlay?.classList.remove("hidden");
                console.log("open");
            }

            function closeMenu() {
                sidebar?.classList.add("-translate-x-full");
                overlay?.classList.add("hidden");
                console.log("close");
            }

            btn?.addEventListener("click", openMenu);
            overlay?.addEventListener("click", closeMenu);
        </script>
    </body>
</html>
