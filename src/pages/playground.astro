---
const defaultCode = `<div class="grid grid-cols-3 gap-4 p-4">
  <img
    src="https://picsum.photos/id/1015/600/400"
    class="w-[300px] h-[200px] object-cover rounded-lg"
  />

  <img
    src="https://picsum.photos/id/1016/600/400"
    class="w-[300px] h-[200px] object-cover rounded-lg"
  />

  <img
    src="https://picsum.photos/id/1018/600/400"
    class="w-[300px] h-[200px] object-cover rounded-lg"
  />
</div>`;
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <title>Astro Live Preview</title>

        <script src="https://cdn.tailwindcss.com"></script>
    </head>

    <body class="bg-neutral-950 text-white h-screen overflow-hidden">
        <div class="grid grid-cols-2 h-screen">
            <!-- Editor -->
            <div class="border-r border-neutral-800 flex flex-col">
                <div class="p-4 border-b border-neutral-800">
                    <h1 class="text-2xl font-bold">Tailwind Live Editor</h1>
                </div>

                <textarea
                    id="editor"
                    class="flex-1 bg-neutral-900 text-green-400 p-4 outline-none font-mono text-sm resize-none"
                    >{defaultCode}</textarea
                >
            </div>

            <!-- Preview -->
            <div class="bg-white">
                <iframe id="preview" class="w-full h-full border-0"></iframe>
            </div>
        </div>

        <script>
            const editor = document.getElementById("editor");
            const preview = document.getElementById("preview");

            function updatePreview() {
                const code = editor.value;

                preview.srcdoc = `
<!DOCTYPE html>
<html>
<head>
  <script src="https://cdn.tailwindcss.com"><\/script>
</head>

<body class="bg-neutral-950 text-white min-h-screen p-8">
  <main class="max-w-7xl mx-auto">
    <h1 class="text-4xl font-bold mb-8">
      Responsive Tailwind Image Grid
    </h1>

    ${code}
  </main>
</body>
</html>
`;
            }

            editor.addEventListener("input", updatePreview);

            updatePreview();
        </script>
    </body>
</html>
