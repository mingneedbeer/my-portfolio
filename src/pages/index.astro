    <!-- LEFT -->
    <div class="left">
      <h1>Szuyi Wang</h1>
      <p>
        Designer / Creative Developer<br />
        Minimal portfolio layout test
      </p>
    </div>

    <!-- RIGHT -->
    <div>
      <Section
        title="Project One"
        image="https://picsum.photos/800/500?1"
        description="Clean layout with strong spacing."
      />

      <Section
        title="Project Two"
        image="https://picsum.photos/800/500?2"
        description="Responsive grid-based design."
      />

      <Section
        title="Project Three"
        image="https://picsum.photos/800/500?3"
        description="Typography-driven UI."
      />
    </div>

  </div>
</BaseLayout>
